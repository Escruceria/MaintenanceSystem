generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum AssetStatus {
  ACTIVE
  IN_MAINTENANCE
  OUT_OF_SERVICE
  RETIRED
}

enum WorkOrderStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceType {
  CORRECTIVE
  PREVENTIVE
  PREDICTIVE
  INSPECTION
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  ON_DATE
}

enum WorkOrderChecklistItemStatus {
  PENDING
  COMPLETED
  NOT_COMPLETED
  NOT_APPLICABLE
}

enum WorkOrderEvidenceType {
  PHOTO
  DOCUMENT
  NOTE
}

enum UserInvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

enum ServiceRequestStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  CONVERTED
  CLOSED
}

enum LocationType {
  SITE
  BUILDING
  FLOOR
  AREA
  ROOM
  WAREHOUSE
  POINT
  OTHER
}

model User {
  id                  String                   @id @default(uuid())
  email               String                   @unique
  name                String
  passwordHash        String
  status              UserStatus               @default(INVITED)
  roles               UserRole[]
  refreshTokens       RefreshToken[]
  sentInvitations     UserInvitation[]         @relation("InvitationInviter")
  acceptedInvitations UserInvitation[]         @relation("InvitationAcceptedUser")
  assignedOrders      WorkOrder[]              @relation("AssignedTechnician")
  checklistExecutions WorkOrderChecklistItem[] @relation("ChecklistExecutor")
  workOrderEvidences  WorkOrderEvidence[]      @relation("EvidenceUploader")
  voidedEvidences     WorkOrderEvidence[]      @relation("EvidenceVoider")
  requestedItems      ServiceRequest[]
  auditEvents         AuditEvent[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model UserInvitation {
  id             String               @id @default(uuid())
  email          String
  name           String
  tokenHash      String               @unique
  status         UserInvitationStatus @default(PENDING)
  roleId         String?
  role           Role?                @relation(fields: [roleId], references: [id])
  invitedById    String
  invitedBy      User                 @relation("InvitationInviter", fields: [invitedById], references: [id])
  acceptedUserId String?
  acceptedUser   User?                @relation("InvitationAcceptedUser", fields: [acceptedUserId], references: [id])
  expiresAt      DateTime
  acceptedAt     DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([email])
  @@index([status])
  @@index([roleId])
  @@index([invitedById])
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  users       UserRole[]
  permissions RolePermission[]
  invitations UserInvitation[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Location {
  id          String       @id @default(uuid())
  code        String       @unique
  name        String
  description String?
  type        LocationType @default(AREA)
  isActive    Boolean      @default(true)
  parentId    String?
  parent      Location?    @relation("LocationTree", fields: [parentId], references: [id])
  children    Location[]   @relation("LocationTree")
  assets      Asset[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([parentId])
  @@index([type])
  @@index([isActive])
}

model Asset {
  id               String                 @id @default(uuid())
  code             String                 @unique
  name             String
  description      String?
  serialNumber     String?
  brand            String?
  model            String?
  qrCode           String?                @unique
  status           AssetStatus            @default(ACTIVE)
  locationId       String?
  location         Location?              @relation(fields: [locationId], references: [id])
  workOrders       WorkOrder[]
  maintenancePlans MaintenancePlanAsset[]
  requests         ServiceRequest[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([status])
  @@index([locationId])
  @@index([brand])
}

model WorkOrder {
  id                   String                   @id @default(uuid())
  number               String                   @unique
  title                String
  description          String?
  type                 MaintenanceType
  priority             WorkOrderPriority        @default(MEDIUM)
  status               WorkOrderStatus          @default(OPEN)
  assetId              String
  asset                Asset                    @relation(fields: [assetId], references: [id])
  assignedTechnicianId String?
  assignedTechnician   User?                    @relation("AssignedTechnician", fields: [assignedTechnicianId], references: [id])
  maintenancePlanId    String?
  maintenancePlan      MaintenancePlan?         @relation(fields: [maintenancePlanId], references: [id])
  scheduledAt          DateTime?
  startedAt            DateTime?
  completedAt          DateTime?
  finalNotes           String?
  recommendations      String?
  spareParts           WorkOrderPart[]
  checklistItems       WorkOrderChecklistItem[]
  evidences            WorkOrderEvidence[]
  serviceRequest       ServiceRequest?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
}

model MaintenancePlan {
  id                       String                 @id @default(uuid())
  code                     String                 @unique
  name                     String
  description              String?
  type                     MaintenanceType        @default(PREVENTIVE)
  frequency                String
  frequencyType            MaintenanceFrequency   @default(MONTHLY)
  intervalDays             Int                    @default(30)
  estimatedDurationMinutes Int?
  priority                 WorkOrderPriority      @default(MEDIUM)
  nextDueAt                DateTime?
  lastGeneratedAt          DateTime?
  isActive                 Boolean                @default(true)
  tasks                    MaintenancePlanTask[]
  assets                   MaintenancePlanAsset[]
  workOrders               WorkOrder[]
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([isActive])
  @@index([type])
  @@index([frequencyType])
  @@index([nextDueAt])
}

model MaintenancePlanTask {
  id             String                   @id @default(uuid())
  planId         String
  plan           MaintenancePlan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  sortOrder      Int                      @default(0)
  isRequired     Boolean                  @default(true)
  workOrderItems WorkOrderChecklistItem[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([planId])
}

model WorkOrderChecklistItem {
  id                    String                       @id @default(uuid())
  workOrderId           String
  workOrder             WorkOrder                    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  maintenancePlanTaskId String?
  maintenancePlanTask   MaintenancePlanTask?         @relation(fields: [maintenancePlanTaskId], references: [id], onDelete: SetNull)
  title                 String
  description           String?
  sortOrder             Int                          @default(0)
  isRequired            Boolean                      @default(true)
  status                WorkOrderChecklistItemStatus @default(PENDING)
  notes                 String?
  executedById          String?
  executedBy            User?                        @relation("ChecklistExecutor", fields: [executedById], references: [id])
  executedAt            DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  @@unique([workOrderId, maintenancePlanTaskId])
  @@index([workOrderId])
  @@index([maintenancePlanTaskId])
  @@index([status])
  @@index([executedById])
}

model WorkOrderEvidence {
  id           String                @id @default(uuid())
  workOrderId  String
  workOrder    WorkOrder             @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  type         WorkOrderEvidenceType
  title        String
  description  String?
  fileUrl      String?
  fileName     String?
  mimeType     String?
  uploadedById String
  uploadedBy   User                  @relation("EvidenceUploader", fields: [uploadedById], references: [id])
  voidedAt     DateTime?
  voidedById   String?
  voidedBy     User?                 @relation("EvidenceVoider", fields: [voidedById], references: [id])
  voidReason   String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([workOrderId])
  @@index([type])
  @@index([uploadedById])
  @@index([voidedAt])
  @@index([voidedById])
}

model MaintenancePlanAsset {
  planId     String
  assetId    String
  plan       MaintenancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  asset      Asset           @relation(fields: [assetId], references: [id])
  assignedAt DateTime        @default(now())

  @@id([planId, assetId])
  @@index([assetId])
}

model ServiceRequest {
  id          String               @id @default(uuid())
  title       String
  description String?
  priority    WorkOrderPriority    @default(MEDIUM)
  status      ServiceRequestStatus @default(OPEN)
  assetId     String?
  asset       Asset?               @relation(fields: [assetId], references: [id])
  requesterId String?
  requester   User?                @relation(fields: [requesterId], references: [id])
  workOrderId String?              @unique
  workOrder   WorkOrder?           @relation(fields: [workOrderId], references: [id])
  reviewedAt  DateTime?
  approvedAt  DateTime?
  rejectedAt  DateTime?
  closedAt    DateTime?
  convertedAt DateTime?
  resolution   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assetId])
  @@index([requesterId])
}

model SparePart {
  id              String          @id @default(uuid())
  sku             String          @unique
  name            String
  description     String?
  unit            String
  stock           Int             @default(0)
  minimumStock    Int             @default(0)
  workOrderUsages WorkOrderPart[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model WorkOrderPart {
  workOrderId String
  sparePartId String
  quantity    Int
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  sparePart   SparePart @relation(fields: [sparePartId], references: [id])

  @@id([workOrderId, sparePartId])
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  taxId     String?  @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditEvent {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}
